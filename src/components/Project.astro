---
import GitHubIcon from "./icons/GitHubIcon.astro";
import Tailwind from "./icons/Tailwind.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import React from "./icons/React.astro";
import Java from "./icons/Java.astro";
import IconAstro from "./icons/astroIcon.astro"
import Python from "./icons/Python.astro";
import Langchain from "./icons/Langchain.astro";
import Langgraph from "./icons/Langgraph.astro";


const TAGS = {
  REACT: {
    name: "React.js",
    class: "bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 shadow-sm hover:bg-white/15 hover:border-white/30 transition-all duration-300",
    icon: React,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 shadow-sm hover:bg-white/15 hover:border-white/30 transition-all duration-300",
    icon: Tailwind,
  },
  JAVA: {
    name: "Java",
    class: "bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 shadow-sm hover:bg-white/15 hover:border-white/30 transition-all duration-300",
    icon: Java,
  },
  ASTRO: {
    name: "Astro",
    class: "bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 shadow-sm hover:bg-white/15 hover:border-white/30 transition-all duration-300",
    icon: IconAstro,
  },
  PYTHON: {
    name: "Python",
    class: "bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 shadow-sm hover:bg-white/15 hover:border-white/30 transition-all duration-300",
    icon: Python,
  },

  LANGCHAIN: {
    name: "Langchain",
    class: "bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 shadow-sm hover:bg-white/15 hover:border-white/30 transition-all duration-300",
    icon: Langchain,
  },

  LANGGRAPH: {
    name: "Langgraph",
    class: "bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 shadow-sm hover:bg-white/15 hover:border-white/30 transition-all duration-300",
    icon: Langgraph,
  },

};




const PROJECTS = [


{
    title: "Research Agent web — Investigación y Desarrollo en Programación",
    description:
      "Un asistente de IA web para investigación y aprendizaje de programación — construido con LangGraph, FastAPI y GPT-4o-mini. Hacé una pregunta y el agente decide que herramientas usar en Wikipedia, GitHub o Stack Overflow. ",
    
    link: "https://github.com/AgusDM7/Agente-Ai-Web.git",
    github: "https://github.com/AgusDM7/Agente-Ai-Web",
    image: "/Projects/WebAi.png",
    tags: [TAGS.PYTHON, TAGS.LANGCHAIN, TAGS.LANGGRAPH],
  },


  {
    title: "Local AI RAG Agent",
    description:
      "Agente de inteligencia artificial local con capacidades de Retrieval-Augmented Generation (RAG) para analizar documentos PDF. Desarrollado con Python - Langchain - Ollama - Chromadb. ",
   
    github: "https://github.com/AgusDM7/Local-Ai-RAG.git",
    image: "/Projects/LocalAi.png",
    tags: [TAGS.PYTHON, TAGS.LANGCHAIN],
  },


  {
    title: "El Buen Sabor",
    description:
      "Plataforma web de pedidos de comida con módulo de clientes — autenticación, catálogo, carrito y pagos online — y panel administrativo en tiempo real con WebSockets para gestión de cocina, productos, pedidos y delivery.",
    
    github: "https://github.com/LucasUdrea-dev/ElBuenSabor-frontend-PF25.git",
    image: "/Projects/buensabor.png",
    tags: [TAGS.REACT, TAGS.TAILWIND, TAGS.JAVA],
  },

  
  {
    title: "Reproductor Web Spotify",
    description:
      "Un clon del popular servicio de música Spotify, desarrollado con Astro, React, TypeScript y TailwindCSS. Cuenta con un estado global de reproduccción de música, listas, álbumes y funcionalidades de búsqueda",
    link: "https://spotify-clone-tau-cyan.vercel.app/",
    github: "https://github.com/AgusDM7/Spotify-Clone.git",
    image: "/Projects/spotifyclone.png",
    tags: [TAGS.ASTRO,TAGS.REACT, TAGS.TAILWIND],
  },
];
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-hidden rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
            <img
              alt="Recién llegado vs 5 años en Nueva Zelanda"
              class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
              loading="lazy"
              src={image}
            />
          </div>
        </div>

        <div class="w-full md:w-2/4">
          <h3 class="text-2xl font-bold dark:text-white">{title}</h3>
          <div class="flex flex-wrap mt-2">
            <ul class="flex flex-row mb-2 gap-x-2">
              {tags.map((tag) => (
                <li>
                  <span
                    class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
                  >
                    <tag.icon class="size-5" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div class="mt-2 text-gray-500">{description}</div>
            <footer class="flex items-end justify-start mt-4 gap-x-4">
              {github && (
                <LinkButton href={github}>
                  <GitHubIcon class="size-6" />
                  Code
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  Preview
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>



